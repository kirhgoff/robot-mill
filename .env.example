# Robot Mill - Environment Variables
# Copy to .env and fill in your values

# ─────────────────────────────────────────────────────────────────────────────
# LLM Provider (required - at least one)
# ─────────────────────────────────────────────────────────────────────────────

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4, Codex)
OPENAI_API_KEY=sk-...

# Robot configuration
ROBOT_PROVIDER=anthropic
ROBOT_MODEL=claude-sonnet-4-20250514

# ─────────────────────────────────────────────────────────────────────────────
# Jira Integration (optional)
# ─────────────────────────────────────────────────────────────────────────────

# Your Jira instance
JIRA_HOST=your-company.atlassian.net
JIRA_PROJECT=PROJ
JIRA_EMAIL=robot@your-company.com
JIRA_API_TOKEN=...

# Get your API token at: https://id.atlassian.com/manage-profile/security/api-tokens

# Optional: Robot user account ID in Jira (for auto-assignment)
JIRA_ROBOT_ACCOUNT_ID=

# Optional: Custom field IDs (find in Jira admin)
JIRA_FIELD_HUMAN_BUDDY=customfield_10001
JIRA_FIELD_REPOSITORY=customfield_10002
JIRA_FIELD_BRANCH=customfield_10003
JIRA_FIELD_ROBOT_TASK=customfield_10004

# Optional: Transition IDs for status changes
JIRA_TRANSITION_START=21
JIRA_TRANSITION_NEEDS_INFO=31
JIRA_TRANSITION_REVIEW=41
JIRA_TRANSITION_DONE=51
