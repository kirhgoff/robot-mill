# ══════════════════════════════════════════════════════════════════════════════
# PROJECT-SPECIFIC — update these for each deployment
# ══════════════════════════════════════════════════════════════════════════════

# ── Required secrets ──────────────────────────────────────────────────────────
# Only the key matching PI_PROVIDER (below) is required; startup validation
# checks that one. Provide whichever provider(s) you intend to use:
#   PI_PROVIDER=anthropic  → ANTHROPIC_API_KEY
#   PI_PROVIDER=openrouter → OPENROUTER_API_KEY
#   PI_PROVIDER=openai     → OPENAI_API_KEY
ANTHROPIC_API_KEY=sk-ant-api03-...
OPENROUTER_API_KEY=sk-or-v1-...
OPENAI_API_KEY=sk-proj-...
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Your Telegram chat ID (get it from @userinfobot).
# Comma-separated for multiple users. Leave empty to allow all (dev only).
ALLOWED_CHAT_IDS=123456789

# GitHub HTTPS auth (alternative to SSH key in secrets/)
GITHUB_TOKEN=github_pat_...

# ── Target project (the repo you create variations of) ───────────────────────
# Source repo to create variations from
TARGET_SOURCE_REPO=https://github.com/kirhgoff/vary-workshop.git

# ══════════════════════════════════════════════════════════════════════════════
# DEFAULTS — these usually don't need changing
# ══════════════════════════════════════════════════════════════════════════════

# ── AI provider ───────────────────────────────────────────────────────────────
# PI_PROVIDER: anthropic | openrouter | openai
# For openrouter, PI_MODEL uses the "provider/id" slug form (e.g. openai/gpt-4o
# or anthropic/claude-opus-4.8). OpenRouter can serve OpenAI models too, so one
# OPENROUTER_API_KEY covers both Claude and GPT.
PI_PROVIDER=openrouter
PI_MODEL=anthropic/claude-opus-4.8

# ── Git identity for commits made by the agent ────────────────────────────────
GIT_USER_EMAIL=kirill.lastovirya@gmail.com
GIT_USER_NAME=Kirill Lastovirya

# ── Backend configuration ─────────────────────────────────────────────────────
BACKEND_PORT=3100
LOG_LEVEL=info

# ── Port range for variation dev servers ──────────────────────────────────────
TARGET_PORT_MIN=4001
TARGET_PORT_MAX=4100

# ── Web frontend port ────────────────────────────────────────────────────────
WEB_PORT=3000
