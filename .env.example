# ══════════════════════════════════════════════════════════════════════════════
# PROJECT-SPECIFIC — update these for each deployment
# ══════════════════════════════════════════════════════════════════════════════

# ── Required secrets ──────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
TELEGRAM_BOT_TOKEN=123456:ABC-...

# Your Telegram chat ID (get it from @userinfobot).
# Comma-separated for multiple users. Leave empty to allow all (dev only).
ALLOWED_CHAT_IDS=123456789

# GitHub HTTPS auth (alternative to SSH key in secrets/)
GITHUB_TOKEN=github_pat_...

# ── Target project (the repo you create variations of) ───────────────────────
# Source repo to create variations from
TARGET_SOURCE_REPO=https://github.com/kirhgoff/vary-workshop.git
# Host directory for worktree storage (bind-mounted into container)
TARGET_DATA_PATH=./target-data

# ══════════════════════════════════════════════════════════════════════════════
# DEFAULTS — these usually don't need changing
# ══════════════════════════════════════════════════════════════════════════════

# ── AI provider ───────────────────────────────────────────────────────────────
PI_PROVIDER=anthropic
PI_MODEL=claude-opus-4-6

# ── Git identity for commits made by the agent ────────────────────────────────
GIT_USER_EMAIL=kirill.lastovirya@gmail.com
GIT_USER_NAME=Kirill Lastovirya

# ── Backend configuration ─────────────────────────────────────────────────────
BACKEND_PORT=3100
LOG_LEVEL=info

# ── Port range for variation dev servers ──────────────────────────────────────
TARGET_PORT_MIN=4001
TARGET_PORT_MAX=4100

# ── Web frontend port ────────────────────────────────────────────────────────
WEB_PORT=3000
