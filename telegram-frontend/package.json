{
  "name": "telegram-frontend",
  "version": "1.0.0",
  "description": "Telegram bot frontend that connects to robot-fastify-backend",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "format": "pnpm biome format --write src/"
  },
  "dependencies": {
    "telegraf": "^4.16.3",
    "ws": "^8.18.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "typescript": "^5.8.3"
  }
}
