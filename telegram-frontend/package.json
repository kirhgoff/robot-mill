{
  "name": "telegram-frontend",
  "version": "1.0.0",
  "description": "Telegram bot frontend that connects to robot-fastify-backend",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "format": "pnpm biome format --write src/"
  },
  "dependencies": {
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "telegraf": "^4.16.3",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.15.3",
    "@types/ws": "^8.18.1",
    "typescript": "^6.0.3"
  }
}
