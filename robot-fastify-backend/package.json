{
  "name": "robot-fastify-backend",
  "version": "1.0.0",
  "description": "Agent orchestration backend with Fastify",
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file .env.local --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "format": "pnpm biome format --write src/"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/websocket": "^11.2.0",
    "@sinclair/typebox": "^0.34.49",
    "fastify": "^5.9.0",
    "nanoid": "^5.1.16",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.1",
    "@types/node": "^22.15.3",
    "typescript": "^6.0.3"
  }
}
