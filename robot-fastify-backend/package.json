{
  "name": "robot-fastify-backend",
  "version": "1.0.0",
  "description": "Agent orchestration backend with Fastify",
  "type": "module",
  "scripts": {
    "dev": "bun run --env-file .env.local --watch src/index.ts",
    "start": "bun run src/index.ts",
    "check": "tsc --noEmit",
    "test": "bun test",
    "format": "pnpm biome format --write src/"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.2",
    "@fastify/websocket": "^11.0.1",
    "@sinclair/typebox": "^0.34.33",
    "fastify": "^5.3.2",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.3",
    "typescript": "^5.8.3"
  }
}
