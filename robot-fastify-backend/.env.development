# Local dev overrides — loaded automatically by `bun run dev`
# Copy to .env.local for personal values; this file is committed with safe defaults.

APP_ENV=development

BACKEND_HOST=127.0.0.1
BACKEND_PORT=3100
LOG_LEVEL=debug

